package admin

import (
	"fmt"
	"strings"

	"github.com/dadyutenga/hms-control/internal/db/generated"
)

templ TenantDetail(tenant generated.Tenant, user generated.User, deployments []generated.Deployment, documents []generated.Document) {
	@AdminLayout("Tenant Detail", "") {
		<div style="max-width:1400px; margin:0 auto;">
			<div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:1.5rem; flex-wrap:wrap;">
				<a href="/admin/tenants" style="color:var(--color-muted-fg); text-decoration:none; font-size:0.875rem;">&larr; Back</a>
				<h1 style="font-family:var(--font-heading); font-size:1.5rem; font-weight:700; letter-spacing:-0.025em; color:var(--color-fg);">{ tenant.CompanyName }</h1>
				@StatusBadge(string(tenant.Status))
				@BillingStatusBadge(tenant.BillingStatus)
				<span id="health-badge" style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:var(--color-secondary); color:var(--color-muted-fg);">checking...</span>
			<span id="health-latency" style="font-size:0.75rem; color:var(--color-muted-fg);"></span>
			</div>

			<!-- Verification Actions -->
			if tenant.Status == generated.TenantStatusPendingApproval {
				<div style="background:color-mix(in srgb, var(--color-brand-blue) 6%, var(--color-bg)); border:1px solid var(--color-brand-blue); border-radius:1rem; padding:1rem 1.5rem; margin-bottom:1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.75rem;">
					<div>
						<span style="font-family:var(--font-heading); font-weight:700; font-size:0.9375rem; color:var(--color-fg);">Verification Required</span>
						<p style="font-size:0.75rem; color:var(--color-muted-fg); margin-top:0.25rem;">Review registration details and documents before approving.</p>
					</div>
					<div style="display:flex; gap:0.5rem;">
						<button
							hx-post={ "/admin/tenants/" + tenant.ID.String() + "/approve" }
							hx-confirm="Approve and provision this tenant?"
							style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.625rem 1.5rem; border-radius:9999px; border:none; font-size:0.875rem; font-weight:600; cursor:pointer; background:var(--color-brand-blue); color:#fff; transition:opacity 0.15s ease;"
							onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
							<i data-lucide="check" style="width:1rem; height:1rem;"></i>
							Approve
						</button>
						<button
							hx-post={ "/admin/tenants/" + tenant.ID.String() + "/suspend" }
							hx-confirm="Suspend this tenant?"
							style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.625rem 1.5rem; border-radius:9999px; border:1px solid var(--color-destructive); font-size:0.875rem; font-weight:600; cursor:pointer; background:var(--color-bg); color:var(--color-destructive); transition:all 0.15s ease;"
							onmouseover="this.style.background='var(--color-secondary)'" onmouseout="this.style.background='var(--color-bg)'">
							<i data-lucide="ban" style="width:1rem; height:1rem;"></i>
							Suspend
						</button>
					</div>
				</div>
			}

			<!-- Grid: 2 columns -->
			<div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
				@detailCard("Business & Legal") {
					<dl style="display:flex; flex-direction:column; gap:0.75rem;">
						@detailRow("Company", user.Company)
						@detailRow("Owner", user.Name)
						@detailRow("Email", user.Email)
						if user.Phone != nil {
							@detailRow("Phone", *user.Phone)
						}
						if user.TIN != nil {
							@detailRow("TIN", *user.TIN)
						}
						if user.BrelaNumber != nil {
							@detailRow("BRELA #", *user.BrelaNumber)
						}
						@detailRow("Verified", fmt.Sprintf("%t", user.Verified))
					</dl>
				}
				@detailCard("Hotel Information") {
					<dl style="display:flex; flex-direction:column; gap:0.75rem;">
						if tenant.HotelName != nil {
							@detailRow("Hotel Name", *tenant.HotelName)
						}
						if tenant.Category != nil {
							@detailRow("Category", *tenant.Category)
						}
						if tenant.RoomCount != nil {
							@detailRow("Rooms", fmt.Sprintf("%d", *tenant.RoomCount))
						}
						if tenant.Address != nil {
							@detailRow("Address", *tenant.Address)
						}
						if tenant.City != nil {
							@detailRow("City", *tenant.City)
						}
						if tenant.Country != nil {
							@detailRow("Country", *tenant.Country)
						}
					</dl>
				}
			</div>

			<!-- Grid: Tenant Details + Owner Info -->
			<div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
				@detailCard("System Info") {
					<dl style="display:flex; flex-direction:column; gap:0.75rem;">
						@detailRow("Slug", tenant.Slug)
						@detailRow("Domain", DomainDisplay(tenant.Domain))
						@detailRow("Status", string(tenant.Status))
						@detailRow("DB Name", tenant.DbName)
						@detailRow("Created", tenant.CreatedAt.Format("02 Jan 2006 15:04"))
						if tenant.RequestedSubdomain != nil && *tenant.RequestedSubdomain != "" {
							@detailRow("Subdomain", *tenant.RequestedSubdomain)
						}
						if tenant.AdminName != nil && *tenant.AdminName != "" {
							@detailRow("Admin Name", *tenant.AdminName)
						}
						if tenant.AdminEmail != nil && *tenant.AdminEmail != "" {
							@detailRow("Admin Email", *tenant.AdminEmail)
						}
					</dl>
				}
				@detailCard("Billing") {
					<div style="margin-bottom:0.75rem;">
						@BillingStatusBadge(tenant.BillingStatus)
					</div>
					<dl style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1rem;">
						if tenant.LastPaymentAt != nil {
							@detailRow("Last Payment", tenant.LastPaymentAt.Format("02 Jan 2006"))
						} else {
							@detailRow("Last Payment", "Never")
						}
						if tenant.NextDueAt != nil {
							@detailRow("Next Due", tenant.NextDueAt.Format("02 Jan 2006"))
						} else {
							@detailRow("Next Due", "Not set")
						}
					</dl>
					<a href={ templ.URL("/admin/tenants/" + tenant.ID.String() + "/billing") }
					   style="display:inline-flex; align-items:center; gap:0.375rem; padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.8125rem; font-weight:600; text-decoration:none; background:var(--color-brand-blue); color:#fff; transition:opacity 0.15s ease;"
					   onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
						<i data-lucide="credit-card" style="width:1rem; height:1rem;"></i>
						Manage Billing
					</a>
				}
			</div>

			<!-- Documents Section -->
			if len(documents) > 0 {
				<div style="background:var(--color-bg); border:1px solid var(--color-border); border-radius:1rem; padding:1.5rem; margin-bottom:1rem;">
					<h2 style="font-family:var(--font-heading); font-size:1rem; font-weight:700; color:var(--color-fg); margin-bottom:1rem;">Uploaded Documents</h2>
					<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem;">
						for _, d := range documents {
							<div style="background:var(--color-card); border:1px solid var(--color-border); border-radius:0.75rem; overflow:hidden;">
								<div style="aspect-ratio:4/3; background:var(--color-secondary); display:flex; align-items:center; justify-content:center; overflow:hidden;">
									if strings.HasPrefix(d.MimeType, "image/") {
										<img src={ templ.URL("/" + d.Filename) } alt={ d.OriginalName } style="width:100%; height:100%; object-fit:cover;" loading="lazy"/>
									} else {
										<div style="display:flex; flex-direction:column; align-items:center; gap:0.5rem; color:var(--color-muted-fg);">
											<i data-lucide="file-text" style="width:2.5rem; height:2.5rem;"></i>
											<span style="font-size:0.75rem;">{ d.MimeType }</span>
										</div>
									}
								</div>
								<div style="padding:0.75rem 1rem;">
									<div style="font-size:0.8125rem; font-weight:600; color:var(--color-fg); margin-bottom:0.25rem; word-break:break-all;">{ d.OriginalName }</div>
									<div style="display:flex; justify-content:space-between; align-items:center; gap:0.5rem;">
										<span style="display:inline-flex; align-items:center; padding:0.125rem 0.5rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:var(--color-secondary); color:var(--color-fg);">{ DocTypeLabel(d.DocType) }</span>
										<span style="font-size:0.6875rem; color:var(--color-muted-fg);">{ FormatFileSize(d.SizeBytes) }</span>
									</div>
								</div>
							</div>
						}
					</div>
				</div>
			}

			<!-- Deployment Actions -->
			<div style="background:var(--color-bg); border:1px solid var(--color-border); border-radius:1rem; padding:1.5rem; margin-bottom:1rem;">
				<h2 style="font-family:var(--font-heading); font-size:1rem; font-weight:700; color:var(--color-fg); margin-bottom:1rem;">Deployment Actions</h2>
				<div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
					<button
						hx-post={ "/admin/tenants/" + tenant.ID.String() + "/deployments/start" }
						hx-confirm="Start the tenant container?"
						style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.5rem 1.25rem; border-radius:9999px; border:none; font-size:0.75rem; font-weight:600; cursor:pointer; background:var(--color-brand-blue); color:#fff; transition:opacity 0.15s ease;"
						onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
						<i data-lucide="play" style="width:0.875rem; height:0.875rem;"></i> Start
					</button>
					<button
						hx-post={ "/admin/tenants/" + tenant.ID.String() + "/deployments/stop" }
						hx-confirm="Stop the tenant container?"
						style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.5rem 1.25rem; border-radius:9999px; border:1px solid var(--color-destructive); font-size:0.75rem; font-weight:600; cursor:pointer; background:var(--color-bg); color:var(--color-destructive); transition:all 0.15s ease;"
						onmouseover="this.style.background='var(--color-secondary)'" onmouseout="this.style.background='var(--color-bg)'">
						<i data-lucide="stop-circle" style="width:0.875rem; height:0.875rem;"></i> Stop
					</button>
					if tenant.Status == generated.TenantStatusFailed {
						<button
							hx-post={ "/admin/tenants/" + tenant.ID.String() + "/retry" }
							hx-confirm="Retry provisioning this tenant?"
							style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.5rem 1.25rem; border-radius:9999px; border:none; font-size:0.75rem; font-weight:600; cursor:pointer; background:hsl(25, 80%, 50%); color:#fff; transition:opacity 0.15s ease;"
							onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
							<i data-lucide="refresh-ccw" style="width:0.875rem; height:0.875rem;"></i> Retry
						</button>
					}
					if tenant.Status == generated.TenantStatusActive {
						<button
							hx-post={ "/admin/tenants/" + tenant.ID.String() + "/suspend" }
							hx-confirm="Suspend this tenant?"
							style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.5rem 1.25rem; border-radius:9999px; border:1px solid var(--color-destructive); font-size:0.75rem; font-weight:600; cursor:pointer; background:var(--color-bg); color:var(--color-destructive); transition:all 0.15s ease;"
							onmouseover="this.style.background='var(--color-secondary)'" onmouseout="this.style.background='var(--color-bg)'">
							<i data-lucide="ban" style="width:0.875rem; height:0.875rem;"></i> Suspend
						</button>
					}
					<button
						hx-post={ "/admin/tenants/" + tenant.ID.String() + "/impersonate" }
						hx-confirm="Impersonate this tenant?"
						style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.5rem 1.25rem; border-radius:9999px; border:1px solid var(--color-border); font-size:0.75rem; font-weight:600; cursor:pointer; background:var(--color-bg); color:var(--color-fg); transition:all 0.15s ease;"
						onmouseover="this.style.background='var(--color-secondary)'" onmouseout="this.style.background='var(--color-bg)'">
						<i data-lucide="user-switch" style="width:0.875rem; height:0.875rem;"></i> Impersonate
					</button>
				</div>
			</div>

			<!-- Deployments Table -->
			<div style="background:var(--color-bg); border:1px solid var(--color-border); border-radius:1rem; padding:1.5rem; margin-bottom:1rem;">
				<h2 style="font-family:var(--font-heading); font-size:1rem; font-weight:700; color:var(--color-fg); margin-bottom:1rem;">Deployments</h2>
				if len(deployments) == 0 {
					<p style="color:var(--color-muted-fg); font-size:0.875rem;">No deployments recorded yet.</p>
				} else {
					<table style="width:100%; font-size:0.875rem; border-collapse:collapse;">
						<thead>
							<tr style="border-bottom:1px solid var(--color-border); color:var(--color-muted-fg); text-align:left;">
								<th style="padding:0.5rem 0; font-weight:500;">Action</th>
								<th style="padding:0.5rem 0; font-weight:500;">Status</th>
								<th style="padding:0.5rem 0; font-weight:500;">Created</th>
								<th style="padding:0.5rem 0; font-weight:500;">Completed</th>
								<th style="padding:0.5rem 0; font-weight:500;">Details</th>
							</tr>
						</thead>
						<tbody>
							for _, d := range deployments {
								<tr style="border-bottom:1px solid var(--color-border);">
									<td style="padding:0.625rem 0; color:var(--color-fg);">{ d.Action }</td>
									<td style="padding:0.625rem 0;">@DeploymentStatusBadge(d.Status)</td>
									<td style="padding:0.625rem 0; color:var(--color-muted-fg);">{ d.CreatedAt.Format("02 Jan 2006 15:04") }</td>
									<td style="padding:0.625rem 0; color:var(--color-muted-fg);">
										if d.CompletedAt != nil {
											{ d.CompletedAt.Format("02 Jan 2006 15:04") }
										}
									</td>
									<td style="padding:0.625rem 0;">
										<a href={ templ.URL("/admin/tenants/" + tenant.ID.String() + "/deployments/" + d.ID.String()) }
										   style="display:inline-flex; align-items:center; padding:0.25rem 0.75rem; border-radius:9999px; font-size:0.75rem; font-weight:500; text-decoration:none; background:var(--color-secondary); color:var(--color-fg); transition:all 0.15s ease;"
										   onmouseover="this.style.background='var(--color-muted)'" onmouseout="this.style.background='var(--color-secondary)'">
											View
										</a>
									</td>
								</tr>
							}
						</tbody>
					</table>
				}
			</div>

			<!-- Provision Log -->
			if tenant.ProvisionLog != nil {
				<div style="background:var(--color-bg); border:1px solid var(--color-border); border-radius:1rem; padding:1.5rem;">
					<h2 style="font-family:var(--font-heading); font-size:1rem; font-weight:700; color:var(--color-fg); margin-bottom:1rem;">Provision Log</h2>
					<pre style="border-radius:0.75rem; padding:1rem; font-size:0.75rem; overflow-x:auto; white-space:pre-wrap; background:#1e1e1e; color:#d4d4d4; font-family:monospace;">{ *tenant.ProvisionLog }</pre>
				</div>
			}
		</div>

		<script>
			(function() {
				var badge = document.getElementById('health-badge');
				var latency = document.getElementById('health-latency');
				var tid = '{ tenant.ID.String() }';

				function check() {
					fetch('/admin/tenants/' + tid + '/health')
						.then(function(r) { return r.json(); })
						.then(function(d) {
							badge.textContent = d.status;
							badge.style.background = d.status === 'UP' ? 'hsl(140, 60%, 95%)' : 'hsl(0, 70%, 95%)';
							badge.style.color = d.status === 'UP' ? 'hsl(140, 60%, 35%)' : 'hsl(0, 70%, 40%)';
							if (d.latency_ms) latency.textContent = d.latency_ms + 'ms';
							if (d.error) latency.textContent = d.error;
						})
						.catch(function() {
							badge.textContent = 'ERR';
							badge.style.background = 'hsl(0, 70%, 95%)';
							badge.style.color = 'hsl(0, 70%, 40%)';
						});
				}

				check();
				setInterval(check, 30000);
			})();
		</script>
	}
}

templ detailCard(title string) {
	<div style="background:var(--color-bg); border:1px solid var(--color-border); border-radius:1rem; overflow:hidden;">
		<div style="padding:1.25rem 1.5rem; border-bottom:1px solid var(--color-border);">
			<h2 style="font-family:var(--font-heading); font-size:0.875rem; font-weight:700; color:var(--color-fg);">{ title }</h2>
		</div>
		<div style="padding:1.25rem 1.5rem;">
			{ children... }
		</div>
	</div>
}

templ detailRow(label, value string) {
	<div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
		<dt style="font-size:0.8125rem; color:var(--color-muted-fg);">{ label }</dt>
		<dd style="font-size:0.875rem; color:var(--color-fg); font-weight:500; text-align:right;">{ value }</dd>
	</div>
}

templ BillingStatusBadge(status string) {
	switch status {
		case "paid":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(140, 60%, 95%); color:hsl(140, 60%, 35%);">paid</span>
		case "unpaid":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(35, 90%, 95%); color:hsl(35, 90%, 35%);">unpaid</span>
		case "overdue":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(35, 90%, 95%); color:hsl(35, 90%, 35%);">overdue</span>
		case "suspended":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(0, 70%, 95%); color:hsl(0, 70%, 40%);">suspended</span>
		default:
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:var(--color-secondary); color:var(--color-muted-fg);">{ status }</span>
	}
}

templ DeploymentStatusBadge(status string) {
	switch status {
		case "provisioning":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(200, 80%, 95%); color:hsl(200, 80%, 40%);">provisioning</span>
		case "active":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(140, 60%, 95%); color:hsl(140, 60%, 35%);">active</span>
		case "failed":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(0, 70%, 95%); color:hsl(0, 70%, 40%);">failed</span>
		case "stopped":
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:hsl(35, 90%, 95%); color:hsl(35, 90%, 35%);">stopped</span>
		default:
			<span style="display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.625rem; font-weight:500; background:var(--color-secondary); color:var(--color-muted-fg);">{ status }</span>
	}
}
